BOT_TOKEN=123456789:replace-with-telegram-bot-token
DATABASE_URL=postgresql://user:password@ep-example-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
TELEGRAM_WEBHOOK_SECRET=replace-with-random-url-safe-secret
CRON_SECRET=replace-with-another-random-secret
DEFAULT_TIME=09:00
DEFAULT_TIMEZONE=Europe/Minsk
SCHEDULER_POLL_SECONDS=30
LOG_LEVEL=INFO
PUBLIC_CHANNEL_ID=@public_channel_username

# Used only by the one-time configuration scripts, not by Vercel itself:
APP_URL=https://your-project.vercel.app
QSTASH_TOKEN=replace-with-upstash-qstash-token

# Local long-polling development can omit DATABASE_URL and use SQLite:
# DATABASE_PATH=runtime/bible_bot.db
